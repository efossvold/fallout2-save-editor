{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Fallout 2 save game editor",
  "type": "module",
  "scripts": {
    "build": "vite-react-ssg build",
    "devtools": "vite build",
    "analyze": "vite analyze",
    "deploy": "bunx netlify-cli deploy",
    "deploy:prod": "git hook run pre-commit && bunx netlify-cli deploy --prod",
    "dev": "vite-react-ssg dev",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "lint:watch": "watchexec -w src -c -- bun run lint",
    "lint": "oxlint -c oxlint.config.ts --fix -f stylish",
    "preview": "vite preview",
    "test:watch": "bun test --watch",
    "test": "bun test"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@rolldown/plugin-babel": "^0.2.2",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "reselect": "^5.1.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "vite-react-ssg": "^0.9.1-beta.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vitejs/devtools": "^0.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "netlify-cli": "^24.3.0",
    "oxfmt": "^0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "vite": "^8.0.1",
    "watch-exec": "^1.2.2"
  }
}
